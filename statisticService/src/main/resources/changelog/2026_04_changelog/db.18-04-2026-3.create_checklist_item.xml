<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="create_checklist_item_table" author="marquis">
        <comment>Создание таблицы справочника пунктов чек-листа</comment>
        <createTable tableName="checklist_item">
            <column name="id" type="SMALLINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(10)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="max_penalty" type="SMALLINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="insert_checklist_item_data" author="marquis">
        <comment>Наполнение справочника пунктов чек-листа</comment>
        <insert tableName="checklist_item">
            <column name="id" valueNumeric="1"/>
            <column name="code" value="1"/>
            <column name="description" value="Уточнил имя клиента"/>
            <column name="max_penalty" valueNumeric="3"/>
        </insert>
        <insert tableName="checklist_item">
            <column name="id" valueNumeric="2"/>
            <column name="code" value="2"/>
            <column name="description" value="Назвал свое имя и компанию"/>
            <column name="max_penalty" valueNumeric="3"/>
        </insert>
        <insert tableName="checklist_item">
            <column name="id" valueNumeric="3"/>
            <column name="code" value="3"/>
            <column name="description" value="Уточнил сферу деятельности клиента"/>
            <column name="max_penalty" valueNumeric="3"/>
        </insert>
        <insert tableName="checklist_item">
            <column name="id" valueNumeric="4"/>
            <column name="code" value="4"/>
            <column name="description" value="Выявил ЛПР и ЛВПР"/>
            <column name="max_penalty" valueNumeric="3"/>
        </insert>
        <insert tableName="checklist_item">
            <column name="id" valueNumeric="5"/>
            <column name="code" value="5"/>
            <column name="description" value="Озвучил информационные поводы"/>
            <column name="max_penalty" valueNumeric="2"/>
        </insert>
    </changeSet>

</databaseChangeLog>