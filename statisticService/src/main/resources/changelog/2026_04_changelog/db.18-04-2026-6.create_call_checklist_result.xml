<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="create_call_checklist_result_table" author="marquis">
        <comment>Создание таблицы результатов оценки звонка по пунктам чек-листа</comment>
        <createTable tableName="call_checklist_result">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="call_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_result_call" references="call(id)" deleteCascade="true"/>
            </column>
            <column name="checklist_item_id" type="SMALLINT">
                <constraints nullable="false" foreignKeyName="fk_result_checklist_item" references="checklist_item(id)"/>
            </column>
            <column name="is_completed" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="penalty_points" type="SMALLINT">
                <constraints nullable="false"/>
            </column>
            <column name="recommendation" type="TEXT"/>
        </createTable>
        <addUniqueConstraint tableName="call_checklist_result"
                             columnNames="call_id, checklist_item_id"
                             constraintName="uq_call_checklist_item"/>
    </changeSet>

</databaseChangeLog>