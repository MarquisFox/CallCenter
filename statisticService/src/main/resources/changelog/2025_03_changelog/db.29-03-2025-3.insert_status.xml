<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="29-03-2025-3.1" author="HarrowX">
        <!-- Статус ошибки -->
        <insert tableName="status">
            <column name="id" value="0" />
            <column name="text" value="Ошибка принятия записи на обработку" />
            <column name="code" value="ERROR" />
        </insert>

        <!-- Статус принятия в обработку -->
        <insert tableName="status">
            <column name="id" value="1" />
            <column name="text" value="Запись принята на обработку" />
            <column name="code" value="ACCEPTED" />
        </insert>

        <!-- Статус обработанна тональность -->
        <insert tableName="status">
            <column name="id" value="2" />
            <column name="text" value="Обработаны тональности" />
            <column name="code" value="TONALITY_PROCESSED" />
        </insert>

        <!-- Статус обработаны рекомендации -->
        <insert tableName="status">
            <column name="id" value="3" />
            <column name="text" value="Обработаны рекомендации" />
            <column name="code" value="RECOMMENDATIONS_PROCESSED" />
        </insert>

        <!-- Полностью обработнана -->
        <insert tableName="status">
            <column name="id" value="4" />
            <column name="text" value="Запись успешно обработана" />
            <column name="code" value="FULL_PROCESSED" />
        </insert>
    </changeSet>
</databaseChangeLog>