# PostgreSQL
POSTGRES_DB=statisticservice
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5400

# Kafka
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181
KAFKA_BROKER=kafka:9092

# Настройки ретраев и DLQ
RETRY_MAX_ATTEMPTS=5
RETRY_BACKOFF_MS=1000
RETRY_BACKOFF_MULTIPLIER=2.0
RETRY_MAX_DELAY_MS=60000

DLQ_TOPIC_CALL_REGISTRATION=call.registration-dlq
DLQ_TOPIC_TONALITY_OUTPUT=tonality.analysis.output-dlq
DLQ_TOPIC_GIGACHAT_OUTPUT=recommendation.analysis.output-dlq

# Порты сервисов (внешние)
BITRIX_ADAPTER_PORT=8081
STATISTICS_SERVICE_PORT=8082

# GigaChat
GIGACHAT_API_KEY=MDE5YjI2M2YtYjdiMS03OGIwLTgwMDUtOGQzNjZkY2M3NTFiOmQzNTIyNGQ1LWVmOTYtNDVlMy1hM2RiLTBlNTYzZjU3NWViYQ==

CHECKLIST_ITEMS='[{"code":"1","description":"Уточнил имя клиента","max_penalty":3},{"code":"2","description":"Назвал свое имя и компанию","max_penalty":3},{"code":"3","description":"Уточнил сферу деятельности клиента","max_penalty":3},{"code":"4","description":"Выявил ЛПР и ЛВПР","max_penalty":3},{"code":"5","description":"Озвучил информационные поводы","max_penalty":2}]'

# Kafka топики
CALL_REGISTRATION_TOPIC=call.registration
TRANSCRIPTION_COMPLETED_TOPIC=transcription.completed
TONALITY_INPUT_TOPIC=transcription.completed
TONALITY_OUTPUT_TOPIC=tonality.analysis.output
RECOMMENDATION_INPUT_TOPIC=transcription.completed
RECOMMENDATION_OUTPUT_TOPIC=recommendation.analysis.output

# Путь к модели тональности
TONALITY_MODEL_PATH=/app/fasttext-social-network-model.bin

# Входные/выходные топики для STT
SPEECH_INPUT_TOPIC=call.registration
SPEECH_OUTPUT_TOPIC=transcription.completed

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# настройки для кеширования в Statistics Service
CACHE_TTL_CALLS=300
CACHE_TTL_MANAGER_LIST=600
CACHE_TTL_DASHBOARD=300

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB_TONALITY=2
REDIS_DB_RECOMMENDATION=1
REDIS_DB_STT=0

# STT (Whisper)
WHISPER_MODEL_SIZE=small

# DLQ для STT
DLQ_TOPIC_STT=call.registration-dlq

STATISTICS_INTERNAL_URL=http://statisticservice:8080/api/v1

